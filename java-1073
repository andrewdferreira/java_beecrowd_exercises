import java.io.IOException;
import java.util.Scanner;

public class Main {
 
    public static void main(String[] args) throws IOException {
        Scanner input = new Scanner(System.in);
        
        int n = input.nextInt();
        int counter = 2;
        
        while (counter <= n){
            if (counter % 2 == 0){
                System.out.println(counter + "^" + "2 = " + counter * counter);
            }
            counter += 2;
        }
    }
 
}
